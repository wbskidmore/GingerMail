{
  "name": "gingermail",
  "version": "1.0.0",
  "private": true,
  "description": "GingerMail - cross-platform desktop email + calendar + tasks, ADHD-friendly",
  "author": "William Skidmore",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n renderer,main -c blue,green \"pnpm --filter @gingermail/renderer dev\" \"pnpm --filter @gingermail/main dev\"",
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm --filter @gingermail/renderer build && pnpm --filter @gingermail/main build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "test": "pnpm -r test --if-present",
    "test:e2e": "playwright test",
    "dist": "pnpm prepackage && pnpm build && electron-builder --mac --win",
    "dist:mac": "pnpm prepackage && pnpm build && electron-builder --mac",
    "dist:win": "pnpm prepackage && pnpm build && electron-builder --win",
    "dist:no-ollama": "pnpm build && electron-builder --mac --win",
    "dist:mac:no-ollama": "pnpm build && electron-builder --mac",
    "dist:win:no-ollama": "pnpm build && electron-builder --win",
    "prepackage": "node scripts/fetch-ollama.mjs --all",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3 --module-dir packages/storage",
    "build:icons": "node scripts/build-icons.mjs",
    "fetch:ollama": "node scripts/fetch-ollama.mjs",
    "postinstall": "electron-builder install-app-deps",
    "sbom": "pnpm dlx @cyclonedx/cyclonedx-npm --output-file sbom.cdx.json --output-format JSON",
    "sbom:xml": "pnpm dlx @cyclonedx/cyclonedx-npm --output-file sbom.cdx.xml --output-format XML",
    "audit:prod": "pnpm audit --prod --audit-level high"
  },
  "dependencies": {
    "@gingermail/main": "workspace:*",
    "@gingermail/ai": "workspace:*",
    "@gingermail/core": "workspace:*",
    "@gingermail/providers": "workspace:*",
    "@gingermail/storage": "workspace:*",
    "@azure/msal-node": "^2.13.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "dompurify": "^3.4.7",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.4",
    "googleapis": "^144.0.0",
    "ical.js": "^2.1.0",
    "imapflow": "^1.0.165",
    "jsdom": "^25.0.1",
    "node-machine-id": "^1.1.12",
    "nodemailer": "^6.9.15",
    "tsdav": "^2.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@playwright/test": "^1.48.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.16.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^39.8.5",
    "electron-builder": "^25.0.5",
    "eslint": "^9.11.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^25.0.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.1"
  }
}
