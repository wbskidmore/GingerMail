    "@gingermail/providers": "workspace:*",
    "@gingermail/storage": "workspace:*",
    "dompurify": "^3.4.7",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.4",
    "googleapis": "^144.0.0",
    "jsdom": "^25.0.1",
    "node-machine-id": "^1.1.12",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "electron": "^39.8.5",
    "typescript": "^5.6.2",
    "vitest": "^4.0.0"
  }
}
