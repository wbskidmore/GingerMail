{
  "name": "@gingermail/main",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./entry.cjs",
  "scripts": {
    "dev": "node --watch-path=src --experimental-vm-modules ./scripts/dev.mjs",
