# GingerMail environment template
#
# Copy to `.env` (gitignored) and fill in what you need. EVERYTHING here is
# OPTIONAL: with no values set, the app still runs — you just authenticate mail
# via IMAP/SMTP, POP3, or an Apple app-specific password instead of OAuth, and
# paste a Slack token instead of using Slack OAuth.
#
# These are read at build/dev time by apps/main/src/config.ts and main.ts.
# Do NOT put real secrets in source control.

# --- Google OAuth (Gmail + Google Calendar) ------------------------------------
# Create an OAuth 2.0 "Desktop app" client at https://console.cloud.google.com
# (APIs & Services -> Credentials). Enable the Gmail and Calendar APIs.
GM_GOOGLE_CLIENT_ID=
GM_GOOGLE_CLIENT_SECRET=

# --- Microsoft OAuth (Outlook / Microsoft 365) ---------------------------------
# Register an app at https://entra.microsoft.com (App registrations). Use a
# public/native client redirect. Tenant defaults to "common" (any account).
GM_MICROSOFT_CLIENT_ID=
GM_MICROSOFT_TENANT=common

# --- Slack OAuth (Chat tab) ----------------------------------------------------
# Create an app at https://api.slack.com/apps. Without these you can still paste
# a token in Settings.
GM_SLACK_CLIENT_ID=
GM_SLACK_CLIENT_SECRET=

# --- Local development toggles -------------------------------------------------
# Set by `pnpm dev` automatically; you normally do not set these by hand.
# GM_DEV=1                         # dev mode (loads the Vite dev server, relaxed CSP)
# GM_RENDERER_URL=http://localhost:5173

# --- DANGER: dev-only escape hatches -------------------------------------------
# These DISABLE at-rest encryption and are for local debugging ONLY. Never set
# them in a build you distribute — they defeat the SQLCipher protections.
# GM_ALLOW_PLAINTEXT_VAULT=1       # store the token vault unencrypted
# GM_ALLOW_UNENCRYPTED_DB=1        # open the local cache DB without encryption
