# EditorConfig — https://editorconfig.org
# Keeps indentation, line endings, and whitespace consistent across editors so
# they match Prettier and the pre-commit hook.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Markdown uses two trailing spaces for hard line breaks.
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
